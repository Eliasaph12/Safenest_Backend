# Local Development Environment Variables
# Copy to .env and update for your local setup

# Database (local MySQL)
DATABASE_URL=jdbc:mysql://localhost:3306/ecommerce_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DATABASE_USER=root
DATABASE_PASSWORD=your_local_mysql_password

# Server
SERVER_PORT=8080

# Frontend (for CORS)
FRONTEND_URL=http://localhost:3000

# Admin (if using basic auth)
ADMIN_PASSWORD=admin
